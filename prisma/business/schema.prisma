// 业务库：手写表结构并使用 Prisma Migrate 管理迁移。

generator client {
  provider = "prisma-client"
  output   = "../generated/business"
}

datasource db {
  provider = "mysql"
}

enum AuthMethod {
  PASSWORD
  SMS
}

enum VerificationChannel {
  SMS
}

enum VerificationPurpose {
  LOGIN
  REGISTER
}

enum SearchPriceCode {
  TRADEMARK_IMAGE_SEARCH
}

enum TransactionType {
  RECHARGE
  SEARCH_DEBIT
  ADMIN_ADJUSTMENT
}

enum SearchRecordStatus {
  SUCCESS
  FAILED
}

enum PaymentMethod {
  BALANCE @map("balance")
  WECHAT  @map("wechat")
  STRIPE  @map("stripe")
  ALIPAY  @map("alipay")
  MANUAL  @map("manual")
}

enum PaymentProvider {
  WECHAT @map("wechat")
  ALIPAY @map("alipay")
  STRIPE @map("stripe")
}

enum PaymentConfigStatus {
  ENABLED  @map("enabled")
  DISABLED @map("disabled")
}

enum ChargeOrderStatus {
  PENDING    @map("pending")
  PROCESSING @map("processing")
  SUCCESS    @map("success")
  FAILED     @map("failed")
  CLOSED     @map("closed")
}

model User {
  id                  Int                @id @default(autoincrement())
  username            String?            @unique
  phone               String?            @unique
  email               String?            @unique
  avatar              String             @default("")
  passwordHash        String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  account             Account?
  searchPrices        SearchPrice[]
  transactions        Transaction[]
  searchRecords       TrademarkSearchRecord[]
  verificationCodes   VerificationCode[]
  operatedChargeOrders ChargeOrder[]     @relation("UserOperatedChargeOrders")
}

model Account {
  id            Int                    @id @default(autoincrement())
  userId        Int                    @unique
  balance       BigInt                 @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  searchRecords TrademarkSearchRecord[]
  chargeOrders  ChargeOrder[]
}

model SearchPrice {
  id            Int                    @id @default(autoincrement())
  code          SearchPriceCode
  userId        Int?
  amount        BigInt
  enabled       Boolean                @default(true)
  note          String?                @db.VarChar(255)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  user          User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  searchRecords TrademarkSearchRecord[]

  @@index([code, enabled])
  @@index([userId])
  @@unique([code, userId])
}

model Transaction {
  id            BigInt                 @id @default(autoincrement())
  userId        Int
  accountId     Int
  type          TransactionType
  amount        BigInt
  balanceBefore BigInt
  balanceAfter  BigInt
  description   String?                @db.VarChar(255)
  bizId         String?                @db.VarChar(64)
  metadata      Json?
  createdAt     DateTime               @default(now())
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  searchRecords TrademarkSearchRecord[]
  chargeOrders  ChargeOrder[]

  @@index([userId, createdAt])
  @@index([accountId, createdAt])
  @@index([type, createdAt])
  @@unique([bizId])
  @@map("trsanction")
}

model PaymentConfig {
  id            Int                 @id @default(autoincrement())
  provider      PaymentProvider     @unique
  displayName   String              @db.VarChar(64)
  description   String?             @db.Text
  icon          String?             @db.Text
  status        PaymentConfigStatus @default(ENABLED)
  sortOrder     Int                 @default(0)
  presetAmounts Json
  minAmount     Int                 @default(1)
  maxAmount     Int                 @default(100000)
  publicConfig  Json
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  chargeOrders  ChargeOrder[]

  @@index([status, sortOrder])
}

model ChargeOrder {
  id                    Int               @id @default(autoincrement())
  accountId             Int
  amount                BigInt
  provider              PaymentMethod
  outTradeNo            String            @unique @db.VarChar(64)
  externalTransactionId String?           @db.VarChar(64)
  paymentCredential     Json
  status                ChargeOrderStatus @default(PENDING)
  expireTime            DateTime?
  paidAt                DateTime?
  transactionId         BigInt?
  operatorId            Int?
  paymentConfigId       Int?
  metadata              Json
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  account               Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transaction           Transaction?      @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  operator              User?             @relation("UserOperatedChargeOrders", fields: [operatorId], references: [id], onDelete: SetNull)
  paymentConfig         PaymentConfig?    @relation(fields: [paymentConfigId], references: [id], onDelete: SetNull)

  @@index([accountId, createdAt])
  @@index([status, createdAt])
  @@index([provider, createdAt])
  @@index([outTradeNo])
  @@index([externalTransactionId])
  @@index([expireTime])
  @@unique([provider, externalTransactionId])
}

model TrademarkSearchRecord {
  id                  BigInt            @id @default(autoincrement())
  userId              Int
  accountId           Int
  searchPriceId       Int?
  transactionId       BigInt?
  requestId           String?           @unique @db.VarChar(64)
  status              SearchRecordStatus @default(SUCCESS)
  searchPriceAmount   BigInt
  queryImageObjectKey String            @db.VarChar(1024)
  queryImageUrl       String            @db.VarChar(2048)
  queryImageSha256    String            @db.VarChar(64)
  queryImageMimeType  String            @db.VarChar(128)
  queryImageSize      Int
  queryVector         Json
  vectorProvider      String            @db.VarChar(128)
  vectorModel         String            @db.VarChar(255)
  vectorDimension     Int
  vectorLatencyMs     Int?
  milvusCollection    String            @db.VarChar(255)
  milvusTopK          Int
  milvusLatencyMs     Int?
  milvusResultCount   Int               @default(0)
  milvusResults       Json
  matchedSerialNums   Json
  matchedRecords      Json
  responseItems       Json
  resultCount         Int               @default(0)
  errorMessage        String?           @db.Text
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  completedAt         DateTime?
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account             Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  searchPrice         SearchPrice?      @relation(fields: [searchPriceId], references: [id], onDelete: SetNull)
  transaction         Transaction?      @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([accountId, createdAt])
  @@index([status, createdAt])
}

model AuthMethodConfig {
  id        Int        @id @default(autoincrement())
  method    AuthMethod @unique
  enabled   Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model VerificationCode {
  id          Int                 @id @default(autoincrement())
  recipient   String
  channel     VerificationChannel
  purpose     VerificationPurpose
  codeHash    String
  expiresAt   DateTime
  used        Boolean             @default(false)
  attempts    Int                 @default(0)
  maxAttempts Int                 @default(5)
  userId      Int?
  createdAt   DateTime            @default(now())
  user        User?               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recipient, purpose])
  @@index([expiresAt])
}
