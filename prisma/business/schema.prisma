// 业务库：手写表结构并使用 Prisma Migrate 管理迁移。

generator client {
  provider = "prisma-client"
  output   = "../generated/business"
}

datasource db {
  provider = "mysql"
}

enum AuthMethod {
  PASSWORD
  SMS
}

enum VerificationChannel {
  SMS
}

enum VerificationPurpose {
  LOGIN
  REGISTER
}

enum SearchPriceCode {
  TRADEMARK_IMAGE_SEARCH
}

enum TransactionType {
  RECHARGE
  SEARCH_DEBIT
  ADMIN_ADJUSTMENT
}

enum SearchRecordStatus {
  SUCCESS
  FAILED
}

model User {
  id                Int                @id @default(autoincrement())
  username          String?            @unique
  phone             String?            @unique
  email             String?            @unique
  avatar            String             @default("")
  passwordHash      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  account           Account?
  searchPrices      SearchPrice[]
  transactions      Transaction[]
  searchRecords     TrademarkSearchRecord[]
  verificationCodes VerificationCode[]
}

model Account {
  id            Int                    @id @default(autoincrement())
  userId        Int                    @unique
  balance       BigInt                 @default(0)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]
  searchRecords TrademarkSearchRecord[]
}

model SearchPrice {
  id            Int                    @id @default(autoincrement())
  code          SearchPriceCode
  userId        Int?
  amount        BigInt
  enabled       Boolean                @default(true)
  note          String?                @db.VarChar(255)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  user          User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  searchRecords TrademarkSearchRecord[]

  @@index([code, enabled])
  @@index([userId])
  @@unique([code, userId])
}

model Transaction {
  id            BigInt                 @id @default(autoincrement())
  userId        Int
  accountId     Int
  type          TransactionType
  amount        BigInt
  balanceBefore BigInt
  balanceAfter  BigInt
  description   String?                @db.VarChar(255)
  bizId         String?                @db.VarChar(64)
  metadata      Json?
  createdAt     DateTime               @default(now())
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  searchRecords TrademarkSearchRecord[]

  @@index([userId, createdAt])
  @@index([accountId, createdAt])
  @@index([type, createdAt])
  @@map("trsanction")
}

model TrademarkSearchRecord {
  id                  BigInt            @id @default(autoincrement())
  userId              Int
  accountId           Int
  searchPriceId       Int?
  transactionId       BigInt?
  requestId           String?           @unique @db.VarChar(64)
  status              SearchRecordStatus @default(SUCCESS)
  searchPriceAmount   BigInt
  queryImageObjectKey String            @db.VarChar(1024)
  queryImageUrl       String            @db.VarChar(2048)
  queryImageSha256    String            @db.VarChar(64)
  queryImageMimeType  String            @db.VarChar(128)
  queryImageSize      Int
  queryVector         Json
  vectorProvider      String            @db.VarChar(128)
  vectorModel         String            @db.VarChar(255)
  vectorDimension     Int
  vectorLatencyMs     Int?
  milvusCollection    String            @db.VarChar(255)
  milvusTopK          Int
  milvusLatencyMs     Int?
  milvusResultCount   Int               @default(0)
  milvusResults       Json
  matchedSerialNums   Json
  matchedRecords      Json
  responseItems       Json
  resultCount         Int               @default(0)
  errorMessage        String?           @db.Text
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  completedAt         DateTime?
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account             Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  searchPrice         SearchPrice?      @relation(fields: [searchPriceId], references: [id], onDelete: SetNull)
  transaction         Transaction?      @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([accountId, createdAt])
  @@index([status, createdAt])
}

model AuthMethodConfig {
  id        Int        @id @default(autoincrement())
  method    AuthMethod @unique
  enabled   Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model VerificationCode {
  id          Int                 @id @default(autoincrement())
  recipient   String
  channel     VerificationChannel
  purpose     VerificationPurpose
  codeHash    String
  expiresAt   DateTime
  used        Boolean             @default(false)
  attempts    Int                 @default(0)
  maxAttempts Int                 @default(5)
  userId      Int?
  createdAt   DateTime            @default(now())
  user        User?               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([recipient, purpose])
  @@index([expiresAt])
}
